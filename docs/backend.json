
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the GameFlashX platform, storing essential information and reward-related metrics.",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "points": {
          "type": "number"
        },
        "balance": {
          "type": "number"
        },
        "totalEarnings": {
          "type": "number"
        },
        "offersCompleted": {
          "type": "number"
        },
        "rewardsUnlocked": {
          "type": "number"
        },
        "referralsCount": {
          "type": "number"
        },
        "referralEarnings": {
          "type": "number"
        },
        "lastLoginAt": {
          "type": "string",
          "format": "date-time"
        },
        "loginStreak": {
          "type": "number"
        },
        "lastSpinAt": {
          "type": "string",
          "format": "date-time"
        },
        "referralCode": {
          "type": "string"
        },
        "accountStatus": {
          "type": "string",
          "enum": ["active", "suspended"]
        }
      },
      "required": [
        "id",
        "email",
        "createdAt",
        "balance",
        "totalEarnings",
        "offersCompleted",
        "rewardsUnlocked"
      ]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Represents an individual earning or spending event.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["offer", "referral", "daily_bonus", "spin", "withdrawal"]
        },
        "amount": {
          "type": "number"
        },
        "rewardName": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "pending", "failed"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "userId", "type", "amount", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores individual user profile data."
        }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": {
            "$ref": "#/backend/entities/Transaction"
          },
          "description": "Stores all financial activity for users."
        }
      }
    ]
  }
}
