{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile, financial statistics, and referral information within the GameFlashX platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity, linking to an external authentication system."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "username": {
          "type": "string"
        },
        "balance": {
          "type": "number",
          "description": "The current available balance for the user."
        },
        "totalEarnings": {
          "type": "number",
          "description": "The total lifetime earnings accumulated by the user."
        },
        "pendingEarnings": {
          "type": "number",
          "description": "Earnings awaiting manual verification."
        },
        "totalReferrals": {
          "type": "number",
          "description": "The total count of users successfully referred."
        },
        "referralCode": {
          "type": "string",
          "description": "A unique code assigned to the user for referral tracking."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Flag indicating if the user has administrative privileges."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastActivityAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "balance",
        "totalEarnings",
        "pendingEarnings",
        "totalReferrals",
        "createdAt"
      ]
    },
    "UserTaskCompletion": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserTaskCompletion",
      "type": "object",
      "description": "Records a specific instance of a user attempting or completing a task.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Verified", "Rejected"]
        },
        "rewardAmount": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "taskId",
        "status",
        "rewardAmount",
        "createdAt"
      ]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Records all financial movements.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["reward", "withdrawal", "referral", "bonus"]
        },
        "amount": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "completed", "failed"]
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "type",
        "amount",
        "status",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile"
        }
      },
      {
        "path": "/users/{userId}/taskCompletions/{completionId}",
        "definition": {
          "entityName": "UserTaskCompletion"
        }
      },
      {
        "path": "/users/{userId}/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction"
        }
      }
    ]
  }
}