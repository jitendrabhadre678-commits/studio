
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the GameFlashX platform, storing essential information and reward-related metrics.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The email address associated with the user's account.",
          "format": "email"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user's account was created.",
          "format": "date-time"
        },
        "points": {
          "type": "number",
          "description": "Total points accumulated."
        },
        "balance": {
          "type": "number",
          "description": "Total earned currency balance (USD)."
        },
        "offersCompleted": {
          "type": "number",
          "description": "Total number of advertiser offers completed."
        },
        "rewardsUnlocked": {
          "type": "number",
          "description": "Total count of rewards unlocked."
        }
      },
      "required": [
        "id",
        "email",
        "createdAt",
        "points",
        "balance",
        "offersCompleted",
        "rewardsUnlocked"
      ]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Represents an individual earning event from an offer completion.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "offerId": {
          "type": "string"
        },
        "rewardAmount": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "pending"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "userId", "rewardAmount", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores individual user profile data.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            }
          ]
        }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": {
            "$ref": "#/backend/entities/Transaction"
          },
          "description": "Stores user transactions for offer completions.",
          "params": [
            {
              "name": "transactionId",
              "description": "The unique identifier of the transaction."
            }
          ]
        }
      }
    ]
  }
}
