
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      // Allow the owner to update everything, OR allow anyone to increment the referral count
      allow update: if (isOwner(userId) && request.resource.data.id == resource.data.id)
                    || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referralsCount'])
                        && request.resource.data.referralsCount == resource.data.referralsCount + 1);
      allow delete: if isOwner(userId);
    }

    match /transactions/{transactionId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /referrals/{referrerId} {
      // Users can see their own referral stats
      allow get: if isOwner(referrerId);
      
      // Anyone can increment a click count (for visitors)
      // We enforce that they only increment 'clicks' and update 'lastUpdated'
      allow create: if request.resource.data.clicks == 1;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks', 'lastUpdated'])
                    && request.resource.data.clicks == resource.data.clicks + 1;
    }
  }
}
