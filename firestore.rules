rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GAMEFLASHX DASHBOARD - SECURITY RULES
     * 
     * Enforces path-based ownership and restricted verification logic.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Validation helpers
    function isValidStatusTransition() {
      // Users can only set status to 'Pending' on creation
      return request.resource.data.status == 'Pending' || isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /taskCompletions/{completionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && 
                        request.resource.data.userId == userId && 
                        request.resource.data.status == 'Pending';
        // Only Admin can move tasks to 'Verified'
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /transactions/{transactionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isAdmin();
      }
    }

    // Public Collections
    match /tasks/{taskId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /giftCards/{giftCardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}