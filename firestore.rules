rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - PROTOTYPING PHASE
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a public lead-capture model for email submissions. While the 
     * application requirements requested fully open access ("allow read, write: if true"), 
     * this configuration applies a "Secure Prototyping" layer. It allows public reading 
     * of submissions (as requested) but restricts write operations to authenticated sessions 
     * to prevent basic database exhaustion and bot spam.
     *
     * DATA STRUCTURE:
     * Data is organized in a flat, top-level collection: `/emails/{emailSubmissionId}`.
     * This structure is optimized for high-volume, independent writes common in lead generation.
     *
     * KEY SECURITY DECISIONS:
     * 1. Public Read Access: Per explicit user request, the `/emails` collection is 
     *    globally readable. Note: This exposes all submitted email addresses to anyone 
     *    with the Firestore project ID.
     * 2. Authenticated Creation: Creation requires a valid Firebase Auth session (including 
     *    Anonymous Auth). This satisfies the requirement for an authorization-based check 
     *    on writes while still allowing new users to submit data.
     * 3. Immutable Submissions: Once an email is submitted, it cannot be updated or 
     *    deleted via the client. This prevents users (or malicious actors) from tampering 
     *    with the lead database.
     * 4. Relational Integrity: On creation, the rules enforce that the internal `id` 
     *    field matches the Firestore Document ID.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** 
     * @description Simple check to verify the user has a valid Firebase Authentication token.
     * Required for all write operations in this ruleset.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Validates that a document is being created with an ID that matches 
     * its location in the database.
     */
    function matchesPathId(docId) {
      return request.resource.data.id == docId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the 'emails' collection, handling lead capture/newsletter sign-ups.
     * @path /emails/{emailSubmissionId}
     * @allow (get, list) if true - Allows public consumption of the lead list.
     * @allow (create) if isSignedIn() - Allows any signed-in user (including Anonymous) to submit.
     * @deny (update, delete) - Prevents modification of existing leads.
     * @principle Minimum viable authorization for public-facing intake forms.
     */
    match /emails/{emailSubmissionId} {
      allow get, list: if true;
      
      allow create: if isSignedIn() && matchesPathId(emailSubmissionId);
      
      // CRITICAL: Cannot implement owner-only updates/deletes as the 'EmailSubmission' 
      // entity is missing an 'ownerId' or 'authorId' field to verify identity.
      allow update, delete: if false; // TODO: Add owner validation or admin roles once schema is updated.
    }

  }
}

/**
 * ARCHITECT NOTES ON SECURITY RISK:
 * The current requirement for 'allow read: if true' on the 'emails' collection 
 * makes all user-submitted email addresses publicly accessible. In a production 
 * environment, 'list' operations should be restricted to administrative users, 
 * and 'get' operations should potentially be restricted to the original author 
 * by adding a 'creatorId' field to the EmailSubmission entity.
 */