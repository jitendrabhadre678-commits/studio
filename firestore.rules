rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a strict user-ownership model for private data (Profiles, Rewards)
     * while allowing public read access to platform content (Tasks, Gift Cards).
     *
     * DATA STRUCTURE
     * - /users/{userId}: Private user profiles, owned by the authenticated user.
     * - /users/{userId}/rewards/{rewardId}: Private rewards associated with a user.
     * - /tasks/{taskId}: Publicly readable tasks, manageable only by administrators.
     * - /giftCardBrands/{brandId}: Publicly readable gift card metadata.
     * - /admins/{adminId}: A restricted collection used to identify administrative users.
     *
     * KEY SECURITY DECISIONS
     * - Ownership is enforced via path parameters (userId) and validated against request.auth.uid.
     * - Platform content (Tasks, Gift Cards) is readable by everyone to allow landing page visibility.
     * - Relational integrity is enforced by requiring 'userId' fields in documents to match the path.
     * - Write access to platform content is restricted to users present in the /admins collection.
     *
     * DENORMALIZATION FOR AUTHORIZATION
     * - User IDs are embedded directly into subcollections (like Rewards) to ensure that 
     *   authorization checks remain fast and independent of parent document lookups.
     */

    // --- Global Helper Functions ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user is an owner and the document currently exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the authenticated user has an entry in the admins collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity. Users can manage their own profile.
     * @path /users/{userId}
     * @allow (create) User 'abc' creates document /users/abc while signed in as 'abc'.
     * @deny (update) User 'abc' tries to update /users/xyz.
     * @principle Enforces strict path-based ownership and self-creation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId) 
                    && request.resource.data.id == userId;
      
      allow update: if isExistingOwner(userId) 
                    && request.resource.data.id == resource.data.id;
      
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for the Reward entity. Subcollection of UserProfile.
       * @path /users/{userId}/rewards/{rewardId}
       * @allow (list) User 'abc' fetches all their rewards from /users/abc/rewards.
       * @deny (create) User 'abc' tries to create a reward for user 'xyz'.
       * @principle Ensures reward data is private to the user and linked correctly.
       */
      match /rewards/{rewardId} {
        allow get, list: if isOwner(userId);
        
        allow create: if isOwner(userId) 
                      && request.resource.data.userId == userId;
        
        allow update: if isExistingOwner(userId) 
                      && request.resource.data.userId == resource.data.userId;
        
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for the Task entity. Public catalog of available tasks.
     * @path /tasks/{taskId}
     * @allow (get) Any visitor views a task description.
     * @deny (update) A regular user tries to change the reward amount of a task.
     * @principle Public read access with restricted admin-only writes.
     */
    match /tasks/{taskId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for GiftCardBrand and its denominations.
     * @path /giftCardBrands/{brandId}
     * @allow (list) Any visitor browses available gift card brands.
     * @deny (delete) A non-admin user tries to delete a brand.
     * @principle Catalog data is public; management is administrative.
     */
    match /giftCardBrands/{brandId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /values/{valueId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    /**
     * @description Rules for the Admin collection (Role-Based Access Control).
     * @path /admins/{adminId}
     * @allow (get) An admin checks their own admin status.
     * @deny (list) A user tries to find out who all the admins are.
     * @principle System-critical collection; writes are typically handled via console/backend.
     */
    match /admins/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow list: if false;
      allow create, update, delete: if false; // Admin roles should be managed via high-privilege environments.
    }
  }
}